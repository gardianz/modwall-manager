# Copy to .env and fill in. The .env file is gitignored (holds your session tokens).
#
# Easiest: let the browser helper fill these for you (one Google login):
#   npm i playwright && npx playwright install chromium
#   node grab-token.mjs --login
#
# Or paste manually from the browser: DevTools (F12) -> Application -> Local Storage ->
#   https://app.modulo.finance -> key starting with "@@auth0spajs@@" -> body.access_token
#   (and body.refresh_token if present).

# Current access token (Auth0 JWT, ~24h life). Required if no REFRESH_TOKEN.
ACCESS_TOKEN=""

# Refresh token (offline_access). If set, the bot auto-renews ACCESS_TOKEN forever.
# Without it the bot can only run until ACCESS_TOKEN expires.
REFRESH_TOKEN=""

# --- optional (defaults shown) ---
# API_BASE=https://modulo-canton-app-api-client-mainnet-prod.fly.dev
# AUTH0_DOMAIN=canton-mainnet-2.us.auth0.com
# AUTH0_CLIENT_ID=IJ0NkQST4x9w7e4BK78PdUktGlvDKVpW
# AUTH0_AUDIENCE=https://client-api.modulo.finance
# ORIGIN=https://app.modulo.finance
# REFRESH_SKEW_SEC=300     # refresh when token has < this many seconds left
# CHECK_EVERY_MIN=30       # --watch loop cadence
# ENABLE_CLAIM=false       # auto-claim the accrued daily reward (POST /api/daily-reward/claim)
# CLAIM_MIN=0              # only claim when accrued >= this
